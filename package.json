{
  "name": "n8n-nodes-epub",
  "version": "0.1.3",
  "description": "n8n community node that converts HTML into an EPUB e-book. Zero runtime dependencies — builds the EPUB (ZIP + OPF + XHTML) in memory. Works on n8n Cloud.",
  "license": "MIT",
  "homepage": "https://github.com/AronStankovics/n8n-nodes-epub",
  "keywords": [
    "n8n-community-node-package",
    "epub",
    "ebook",
    "kindle",
    "kobo",
    "html",
    "newsletter"
  ],
  "author": {
    "name": "Áron Stankovics",
    "email": "stankovics.aron@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AronStankovics/n8n-nodes-epub.git"
  },
  "bugs": {
    "url": "https://github.com/AronStankovics/n8n-nodes-epub/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "mocha",
    "test:watch": "mocha --watch",
    "coverage": "nyc --reporter=text --reporter=lcov mocha",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "nodes/**/*.ts"
    ],
    "exclude": [
      "test/**",
      "dist/**",
      "**/*.d.ts"
    ]
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "nodes": [
      "dist/nodes/HtmlToEpub/HtmlToEpub.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.1",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/chai-spies": "^1.0.6",
    "@types/mocha": "^10.0.10",
    "@types/proxyquire": "^1.3.31",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "chai-spies": "^1.1.0",
    "eslint": "9.39.4",
    "mocha": "^10.8.2",
    "nyc": "^15.1.0",
    "prettier": "3.8.1",
    "proxyquire": "^2.1.3",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
