{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noUnusedLocals": false,
		"declaration": false,
		"sourceMap": false,
		"incremental": false,
		"types": ["mocha", "node", "chai", "chai-as-promised", "chai-spies"]
	},
	"include": ["nodes/**/*", "test/**/*"],
	"ts-node": {
		"transpileOnly": true,
		"files": true,
		"preferTsExts": true
	}
}
